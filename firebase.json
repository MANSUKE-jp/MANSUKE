{
    "hosting": [
        {
            "target": "hirusupa",
            "public": "apps/HIRUSUPA/dist",
            "ignore": [
                "firebase.json",
                "**/.*",
                "**/node_modules/**"
            ],
            "headers": [
                {
                    "source": "/index.html",
                    "headers": [
                        {
                            "key": "Cache-Control",
                            "value": "no-cache, no-store, must-revalidate"
                        }
                    ]
                }
            ],
            "rewrites": [
                {
                    "source": "/api/verifyMansukeToken",
                    "function": "werewolfVerifyMansukeToken"
                },
                {
                    "source": "**",
                    "destination": "/index.html"
                }
            ]
        },
        {
            "target": "werewolf",
            "public": "apps/WEREWOLF/dist",
            "ignore": [
                "firebase.json",
                "**/.*",
                "**/node_modules/**"
            ],
            "headers": [
                {
                    "source": "/index.html",
                    "headers": [
                        {
                            "key": "Cache-Control",
                            "value": "no-cache, no-store, must-revalidate"
                        }
                    ]
                }
            ],
            "rewrites": [
                {
                    "source": "/api/verifyMansukeToken",
                    "function": "werewolfVerifyMansukeToken",
                    "region": "asia-northeast2"
                },
                {
                    "source": "**",
                    "destination": "/index.html"
                }
            ]
        },
        {
            "target": "mymansuke",
            "public": "apps/MyMANSUKE/dist",
            "ignore": [
                "firebase.json",
                "**/.*",
                "**/node_modules/**"
            ],
            "headers": [
                {
                    "source": "/index.html",
                    "headers": [
                        {
                            "key": "Cache-Control",
                            "value": "no-cache, no-store, must-revalidate"
                        }
                    ]
                }
            ],
            "rewrites": [
                {
                    "source": "**",
                    "destination": "/index.html"
                }
            ]
        },
        {
            "target": "mansuke-staff",
            "public": "apps/STAFF/dist",
            "ignore": [
                "firebase.json",
                "**/.*",
                "**/node_modules/**"
            ],
            "headers": [
                {
                    "source": "/index.html",
                    "headers": [
                        {
                            "key": "Cache-Control",
                            "value": "no-cache, no-store, must-revalidate"
                        }
                    ]
                }
            ],
            "rewrites": [
                {
                    "source": "/api/verifyMansukeToken",
                    "function": "staffVerifyMansukeToken",
                    "region": "asia-northeast2"
                },
                {
                    "source": "**",
                    "destination": "/index.html"
                }
            ]
        },
        {
            "target": "mansuke-man02",
            "public": "apps/MAN02/dist",
            "ignore": [
                "firebase.json",
                "**/.*",
                "**/node_modules/**"
            ],
            "headers": [
                {
                    "source": "/index.html",
                    "headers": [
                        {
                            "key": "Cache-Control",
                            "value": "no-cache, no-store, must-revalidate"
                        }
                    ]
                }
            ],
            "rewrites": [
                {
                    "source": "/api/verifyMansukeToken",
                    "function": "man02VerifyMansukeToken",
                    "region": "asia-northeast2"
                },
                {
                    "source": "**",
                    "destination": "/index.html"
                }
            ]
        },
        {
            "target": "homepage",
            "public": "apps/HOMEPAGE/public",
            "ignore": [
                "firebase.json",
                "**/.*"
            ]
        }
    ],
    "functions": [
        {
            "source": "shared/functions",
            "codebase": "default",
            "ignore": [
                "node_modules",
                ".git",
                "firebase-debug.log",
                "firebase-debug.*.log",
                "*.local"
            ]
        }
    ],
    "firestore": [
        {
            "database": "hirusupa",
            "rules": "firestore/hirusupa.rules"
        },
        {
            "database": "werewolf",
            "rules": "firestore/werewolf.rules",
            "indexes": "firestore/werewolf.indexes.json"
        },
        {
            "database": "users",
            "rules": "firestore/users.rules",
            "indexes": "firestore/users.indexes.json"
        },
        {
            "database": "prepaid-card",
            "rules": "firestore/prepaid-card.rules"
        },
        {
            "database": "orders",
            "rules": "firestore/orders.rules"
        },
        {
            "database": "man02",
            "rules": "firestore/man02.rules"
        }
    ],
    "storage": {
        "rules": "storage.rules"
    }
}