{
    "name": "mansuke-workspace",
    "private": true,
    "version": "1.0.0",
    "workspaces": [
        "apps/*",
        "shared"
    ],
    "scripts": {
        "dev": "npm run dev --workspaces --if-present",
        "build": "npm run build --workspaces --if-present",
        "start:hirusupa": "npm run dev -w apps/HIRUSUPA",
        "start:werewolf": "npm run dev -w apps/WEREWOLF",
        "start:mymansuke": "npm run dev -w apps/MyMANSUKE",
        "deploy:all": "firebase deploy",
        "deploy:hirusupa": "firebase deploy --only hosting:hirusupa,functions:hirusupa-functions,firestore:hirusupa",
        "deploy:werewolf": "firebase deploy --only hosting:werewolf,functions:werewolf-functions,firestore:werewolf",
        "deploy:mymansuke": "firebase deploy --only hosting:mymansuke,functions:mymansuke-functions,firestore:mymansuke",
        "deploy:homepage": "firebase deploy --only hosting:homepage",
        "generate-icons": "node shared/scripts/generate-icons.js"
    },
    "dependencies": {
        "firebase": "^11.10.0",
        "framer-motion": "^12.34.3",
        "lucide-react": "^0.575.0"
    },
    "devDependencies": {
        "sharp": "^0.34.5"
    }
}
